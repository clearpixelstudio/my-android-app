<!-- ===================== PRODUCT DETAIL PAGE ===================== -->
<div class="page" id="page-product">
  <div class="detail-img-wrap" id="detail-img-wrap">
    <img id="d-main-img" class="detail-main-img" src="" alt="">
    <div class="detail-float-btns">
      <button class="float-btn" onclick="goBack()">←</button>
      <button class="float-btn" onclick="shareProduct()">⬆️</button>
    </div>
  </div>
  <div class="detail-thumbs" id="d-thumbs"></div>
  <div class="detail-info">
    <div class="d-cat" id="d-cat"></div>
    <h2 class="d-name" id="d-name"></h2>
    <div class="d-rating-row">
      <div class="d-rating-pill">⭐ <span id="d-rating">4.5</span></div>
      <span style="font-size:13px;color:var(--text-muted)" id="d-reviews"></span>
      <span class="tag tag-green" id="d-stock">In Stock</span>
    </div>
    <div class="d-price-row">
      <div class="d-price" id="d-price"></div>
      <div class="d-orig" id="d-orig"></div>
      <div class="d-disc" id="d-disc"></div>
    </div>
    <div class="d-highlights">
      <ul id="d-highlights-list">
        <li>Free delivery on this order</li>
        <li>Easy 7-day return & exchange</li>
        <li>COD available</li>
      </ul>
    </div>

    <!-- PINCODE CHECK -->
    <div class="pincode-check">
      <label>📍 Check Delivery to Your Pincode</label>
      <div class="pincode-row">
        <input type="tel" id="pin-input" placeholder="Enter 6-digit pincode" maxlength="6">
        <button onclick="checkPincode()">Check</button>
      </div>
      <div class="pincode-result" id="pin-result"></div>
    </div>

    <div class="delivery-box">
      <p>🚚 Estimated delivery in <strong id="d-delivery">4–6 business days</strong></p>
      <p>↩️ 7-day hassle-free return policy</p>
      <p>💳 Pay via UPI, Card or Cash on Delivery</p>
    </div>

    <div class="d-section-title">📝 Description</div>
    <div class="d-desc" id="d-desc"></div>

    <div class="d-section-title">📋 Specifications</div>
    <div class="d-specs"><table id="d-specs-table"></table></div>

    <div class="d-section-title">💬 Customer Reviews</div>
    <div id="d-reviews-list"></div>

    <!-- ADD REVIEW FORM -->
    <div style="background:var(--bg);border-radius:12px;padding:14px;margin-top:10px">
      <div style="font-size:14px;font-weight:800;margin-bottom:10px">Write a Review</div>
      <div style="font-size:12px;color:var(--text-muted);margin-bottom:6px">Your Rating</div>
      <div class="star-picker" id="star-picker">
        <span class="star-opt" data-val="1" onclick="setReviewStar(1)">⭐</span>
        <span class="star-opt" data-val="2" onclick="setReviewStar(2)">⭐</span>
        <span class="star-opt" data-val="3" onclick="setReviewStar(3)">⭐</span>
        <span class="star-opt" data-val="4" onclick="setReviewStar(4)">⭐</span>
        <span class="star-opt" data-val="5" onclick="setReviewStar(5)">⭐</span>
      </div>
      <div class="fg" style="margin-bottom:8px">
        <input type="text" id="rv-name" placeholder="Your name">
      </div>
      <div class="fg" style="margin-bottom:8px">
        <textarea id="rv-text" rows="2" placeholder="Share your experience..." style="resize:none;width:100%;border:1.5px solid var(--border);border-radius:9px;padding:10px 12px;font-size:14px;font-family:var(--font);outline:none"></textarea>
      </div>
      <button onclick="submitReview()" style="background:var(--primary);color:white;border:none;border-radius:9px;padding:10px 20px;font-size:13px;font-weight:800;cursor:pointer;font-family:var(--font)">Submit Review</button>
    </div>

    <div class="divider" style="margin:14px -14px"></div>
    <div class="d-section-title">🛍️ Similar Products</div>
    <div class="products-scroll" id="d-similar"></div>
    <div style="height:80px"></div>
  </div>
  <div class="detail-actions">
    <button class="d-wish" id="d-wish-btn" onclick="toggleWishlistCurrent()">❤️</button>
    <button class="d-cart" onclick="addToCartCurrent()">Add to Cart</button>
    <button class="d-buy" onclick="buyNow()">Buy Now ⚡</button>
  </div>
</div>

<!-- ===================== CART PAGE ===================== -->
<div class="page" id="page-cart">
  <div class="page-header">
    <button class="back-btn" onclick="goBack()">←</button>
    <span class="page-title">🛒 My Cart</span>
    <span style="font-size:13px;color:var(--text-muted);margin-left:auto" id="cart-item-count"></span>
  </div>
  <div id="cart-body"></div>
</div>

<!-- ===================== CHECKOUT PAGE ===================== -->
<div class="page" id="page-checkout">
  <div class="page-header">
    <button class="back-btn" onclick="goBack()">←</button>
    <span class="page-title">Checkout</span>
  </div>

  <!-- STEPS INDICATOR -->
  <div class="steps-bar">
    <div class="step-item">
      <div class="step-num active" id="sn1">1</div>
      <div class="step-label active" id="sl1">Address</div>
    </div>
    <div class="step-sep" id="ss1"></div>
    <div class="step-item">
      <div class="step-num" id="sn2">2</div>
      <div class="step-label" id="sl2">Shipping</div>
    </div>
    <div class="step-sep" id="ss2"></div>
    <div class="step-item">
      <div class="step-num" id="sn3">3</div>
      <div class="step-label" id="sl3">Payment</div>
    </div>
    <div class="step-sep" id="ss3"></div>
    <div class="step-item">
      <div class="step-num" id="sn4">4</div>
      <div class="step-label" id="sl4">Review</div>
    </div>
  </div>

  <!-- STEP 1: ADDRESS -->
  <div id="co-step1">
    <div class="form-card">
      <h3>📍 Delivery Address</h3>
      <div class="fg" id="fg-name">
        <label>Full Name *</label>
        <input type="text" id="co-name" placeholder="Enter your full name">
        <div class="error-msg">Please enter your full name</div>
      </div>
      <div class="fg" id="fg-phone">
        <label>Phone Number *</label>
        <input type="tel" id="co-phone" placeholder="10-digit mobile number" maxlength="10">
        <div class="error-msg">Please enter a valid 10-digit number</div>
      </div>
      <div class="fg">
        <label>Email (Optional)</label>
        <input type="email" id="co-email" placeholder="your@email.com">
      </div>
      <div class="fg" id="fg-address">
        <label>House/Flat, Street, Locality *</label>
        <textarea id="co-address" rows="2" placeholder="House no., street, locality, landmark" style="resize:none;width:100%;border:1.5px solid var(--border);border-radius:9px;padding:10px 12px;font-size:14px;font-family:var(--font);outline:none"></textarea>
        <div class="error-msg">Please enter your address</div>
      </div>
      <div class="form-row">
        <div class="fg" id="fg-city">
          <label>City *</label>
          <input type="text" id="co-city" placeholder="City">
          <div class="error-msg">Required</div>
        </div>
        <div class="fg" id="fg-pin">
          <label>Pincode *</label>
          <input type="tel" id="co-pin" placeholder="6-digit" maxlength="6">
          <div class="error-msg">6-digit pincode</div>
        </div>
      </div>
      <div class="fg" id="fg-state">
        <label>State *</label>
        <select id="co-state">
          <option value="">Select State</option>
          <option>Andhra Pradesh</option><option>Arunachal Pradesh</option><option>Assam</option>
          <option>Bihar</option><option>Chhattisgarh</option><option>Delhi</option>
          <option>Goa</option><option>Gujarat</option><option>Haryana</option>
          <option>Himachal Pradesh</option><option>Jharkhand</option><option>Karnataka</option>
          <option>Kerala</option><option>Madhya Pradesh</option><option>Maharashtra</option>
          <option>Manipur</option><option>Meghalaya</option><option>Mizoram</option>
          <option>Nagaland</option><option>Odisha</option><option>Punjab</option>
          <option>Rajasthan</option><option>Sikkim</option><option>Tamil Nadu</option>
          <option>Telangana</option><option>Tripura</option><option>Uttar Pradesh</option>
          <option>Uttarakhand</option><option>West Bengal</option>
          <option>Jammu & Kashmir</option><option>Ladakh</option><option>Puducherry</option>
        </select>
        <div class="error-msg">Please select state</div>
      </div>
    </div>
    <div class="checkout-footer">
      <button class="checkout-btn" onclick="checkoutStep1()">Continue to Shipping →</button>
    </div>
  </div>

  <!-- STEP 2: SHIPPING -->
  <div id="co-step2" style="display:none">
    <div class="form-card">
      <h3>🚚 Shipping Method</h3>
      <div class="shipping-option selected" id="ship-standard" onclick="selectShipping('standard')">
        <div class="pay-radio" id="sr-standard"><div style="width:10px;height:10px;border-radius:50%;background:var(--primary)"></div></div>
        <div class="pay-info">
          <div class="pay-title">Standard Delivery</div>
          <div class="pay-sub">4–6 business days</div>
        </div>
        <div style="font-weight:900;color:var(--success)" id="ship-std-price">FREE</div>
      </div>
      <div class="shipping-option" id="ship-express" onclick="selectShipping('express')">
        <div class="pay-radio" id="sr-express"></div>
        <div class="pay-info">
          <div class="pay-title">Express Delivery ⚡</div>
          <div class="pay-sub">1–2 business days</div>
        </div>
        <div style="font-weight:900;color:var(--primary)">₹99</div>
      </div>
    </div>
    <div class="form-card">
      <h3>🏷️ Coupon Code</h3>
      <div class="coupon-row">
        <input type="text" id="co-coupon" placeholder="Enter coupon (e.g. FLAT10)" style="border:none;background:transparent;flex:1;font-size:13px;font-family:var(--font);outline:none;text-transform:uppercase;padding:0">
        <button onclick="applyCoupon()">Apply</button>
      </div>
      <div id="coupon-msg" style="font-size:12px;font-weight:700;margin-top:4px"></div>
      <div style="margin-top:10px;font-size:11px;color:var(--text-muted)">
        Available codes: <strong>FLAT10</strong> (10% off) · <strong>SHIP49</strong> (Free shipping)
      </div>
    </div>
    <div class="form-card">
      <h3>📋 Order Summary</h3>
      <div id="co-items-list"></div>
      <div class="sum-row"><span>Subtotal</span><span id="co-subtotal">₹0</span></div>
      <div class="sum-row"><span>Shipping</span><span id="co-ship">FREE</span></div>
      <div class="sum-row"><span>Discount</span><span id="co-disc" style="color:var(--success)">—</span></div>
      <div class="sum-row"><span>GST (18%)</span><span id="co-gst">₹0</span></div>
      <div class="sum-row total"><span>Total</span><span id="co-total">₹0</span></div>
    </div>
    <div class="checkout-footer" style="display:flex;gap:10px">
      <button class="big-btn" onclick="coGoStep(1)" style="background:white;color:var(--primary);border:2px solid var(--primary);flex:0 0 auto;padding:13px 18px">← Back</button>
      <button class="checkout-btn" onclick="checkoutStep2()" style="flex:1">Continue to Payment →</button>
    </div>
  </div>

  <!-- STEP 3: PAYMENT METHOD -->
  <div id="co-step3" style="display:none">
    <div class="form-card">
      <h3>💳 Select Payment Method</h3>
      <div class="payment-option selected" id="pay-upi" onclick="selectPayment('upi')">
        <div class="pay-radio" id="pr-upi"><div style="width:10px;height:10px;border-radius:50%;background:var(--primary)"></div></div>
        <div class="pay-info"><div class="pay-title">UPI Payment</div><div class="pay-sub">GPay, PhonePe, Paytm, any UPI</div></div>
        <div class="pay-icon">📲</div>
      </div>
      <div class="payment-option" id="pay-cod" onclick="selectPayment('cod')">
        <div class="pay-radio" id="pr-cod"></div>
        <div class="pay-info"><div class="pay-title">Cash on Delivery</div><div class="pay-sub">Pay when order arrives</div></div>
        <div class="pay-icon">💵</div>
      </div>
      <div class="payment-option" id="pay-card" onclick="selectPayment('card')">
        <div class="pay-radio" id="pr-card"></div>
        <div class="pay-info"><div class="pay-title">Debit/Credit Card</div><div class="pay-sub">Visa, Mastercard, RuPay</div></div>
        <div class="pay-icon">💳</div>
      </div>
      <div class="payment-option" id="pay-netbanking" onclick="selectPayment('netbanking')">
        <div class="pay-radio" id="pr-netbanking"></div>
