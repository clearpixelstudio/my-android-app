/* ============================================================
   STATE
   ============================================================ */
let cart = JSON.parse(localStorage.getItem('si-cart') || '[]');
let wishlist = JSON.parse(localStorage.getItem('si-wishlist') || '[]');
let currentProduct = null;
let currentUser = JSON.parse(localStorage.getItem('si-user') || 'null');
let pageHistory = ['page-home'];
let currentPage = 'page-home';
let selectedShipping = 'standard';
let selectedPayment = 'upi';
let appliedCoupon = null;
let pendingOrder = null;
let reviewStar = 0;
let catOffset = 0;
let currentCatProducts = [];

// Timers
let sliderIdx = 0, sliderTimer, carouselIdx = 0, carouselTimer, countdownTimer;

/* ============================================================
   INIT
   ============================================================ */
document.addEventListener('DOMContentLoaded', () => {
  renderCatGrid();
  renderHomeProducts();
  initSlider();
  initMiniCarousel();
  initMallCats();
  startCountdown();
  updateCartBadge();
  checkUserSession();
  renderReviews();
  renderFAQ();
  renderBlog();

  // Search enter key
  document.getElementById('search-input').addEventListener('keydown', e => {
    if (e.key === 'Enter') doSearch();
  });
});

/* ============================================================
   RENDER FUNCTIONS
   ============================================================ */
function renderCatGrid() {
  document.getElementById('cat-grid').innerHTML = CATEGORIES.slice(0,12).map(c => `
    <div class="cat-item" onclick="showCategory('${c.name}')">
      <div class="cat-icon" style="background:${c.bg}22;font-size:26px">${c.icon}</div>
      <div class="cat-name">${c.name}</div>
    </div>
  `).join('');
}

function productCard(p, scroll=false) {
  const disc = Math.round((p.orig - p.price) / p.orig * 100);
  const inWish = wishlist.includes(p.id);
  return `
    <div class="product-card${scroll?' scroll-card':''}" onclick="openProduct(${p.id})">
      <div class="product-img">
        <img src="${p.img}" alt="${p.name}" loading="lazy">
        <span class="p-badge">${disc}% OFF</span>
        <button class="p-wishlist${inWish?' active':''}" onclick="event.stopPropagation();toggleWishItem(${p.id},this)">
          ${inWish?'❤️':'🤍'}
        </button>
      </div>
      <div class="product-info">
        <div class="product-name">${p.name}</div>
        <div class="product-rating">
          <span class="p-stars">${'⭐'.repeat(Math.round(p.rating))}</span>
          <span class="p-rcount">${p.rating} (${p.reviews.toLocaleString('en-IN')})</span>
        </div>
        <div class="product-price">
          <span class="p-current">₹${p.price.toLocaleString('en-IN')}</span>
          <span class="p-orig">₹${p.orig.toLocaleString('en-IN')}</span>
          <span class="p-off">${disc}% off</span>
        </div>
        <button class="p-add-btn" onclick="event.stopPropagation();addToCart(${p.id})">+ Add to Cart</button>
      </div>
    </div>`;
}

function renderHomeProducts() {
  document.getElementById('trending-products').innerHTML = PRODUCTS.slice(0,6).map(p => productCard(p, true)).join('');
  document.getElementById('flash-products').innerHTML = PRODUCTS.slice(2,8).map(p => productCard(p, true)).join('');
  const budget = PRODUCTS.filter(p => p.price <= 299);
  document.getElementById('budget-products').innerHTML = budget.map(p => productCard(p, true)).join('');
  document.getElementById('bestseller-products').innerHTML = PRODUCTS.slice(0,4).map(p => productCard(p, false)).join('');
}

function renderReviews() {
  document.getElementById('reviews-row').innerHTML = REVIEWS_DATA.map(r => `
    <div class="review-card">
      <div class="reviewer">
        <div class="r-avatar">${r.name[0]}</div>
        <div>
          <div class="r-name">${r.name}</div>
          <div class="r-stars">${'⭐'.repeat(r.rating)}</div>
        </div>
      </div>
      <div class="r-text">${r.text}</div>
      <div class="r-product">Purchased: ${r.product}</div>
    </div>`).join('');
}

function renderFAQ() {
  document.getElementById('faq-list').innerHTML = FAQ_DATA.map((f,i) => `
    <div class="faq-item" id="faq-${i}">
      <div class="faq-q" onclick="toggleFAQ(${i})">
        <span>${f.q}</span>
        <span class="faq-icon">+</span>
      </div>
      <div class="faq-a">${f.a}</div>
    </div>`).join('');
}

function toggleFAQ(i) {
  const el = document.getElementById('faq-' + i);
  el.classList.toggle('open');
}

function renderBlog() {
  document.getElementById('blog-list').innerHTML = BLOG_DATA.map(b => `
    <div class="blog-card" onclick="openArticle(${b.id})">
      <img class="blog-img" src="${b.img}" alt="${b.title}" loading="lazy">
      <div class="blog-info">
        <div class="blog-cat">${b.cat}</div>
        <div class="blog-title">${b.title}</div>
        <div class="blog-excerpt">${b.excerpt}</div>
        <div class="blog-meta">📅 ${b.date} · 5 min read</div>
      </div>
    </div>`).join('');
}

function openArticle(id) {
  const article = BLOG_DATA.find(b => b.id === id);
  if (!article) return;
  document.getElementById('article-body').innerHTML = `
    <img src="${article.img}" style="width:calc(100%+28px);margin:-14px -14px 14px;display:block;height:200px;object-fit:cover" alt="${article.title}">
    <span style="font-size:10px;font-weight:800;color:var(--primary);text-transform:uppercase">${article.cat}</span>
    <h2 style="margin:8px 0;line-height:1.3">${article.title}</h2>
    <div style="font-size:12px;color:var(--text-muted);margin-bottom:16px">📅 ${article.date} · 5 min read</div>
    <p style="font-size:14px;color:var(--text-muted);line-height:1.8">${article.excerpt}<br><br>
    Yeh ek comprehensive guide hai jo aapko in products ke baare mein full knowledge deta hai. Hamari team ne best options select kiye hain aapke budget aur style ke hisab se.<br><br>
    ShopIndia pe yeh sabhi products available hain best prices pe. Shop now and enjoy free delivery on orders above ₹499!</p>
    <div style="margin-top:20px">
      <button class="big-btn" onclick="showPage('page-category')" style="width:100%">🛍️ Shop Now</button>
    </div>`;
  showPage('page-article');
}

function initMallCats() {
  document.getElementById('mall-cats').innerHTML = CATEGORIES.slice(1,9).map(c => `
    <div class="mall-cat" onclick="showCategory('${c.name}')">
      <div class="mall-cat-circle" style="background:${c.bg}33">${c.icon}</div>
      <span>${c.name.split(' ')[0]}</span>
    </div>`).join('');
}

/* ============================================================
   SLIDER
   ============================================================ */
function initSlider() {
  const slider = document.getElementById('main-slider');
  const dots = document.getElementById('slider-dots');
  const count = slider.children.length;
  dots.innerHTML = Array.from({length:count},(_,i) =>
    `<div class="dot${i===0?' active':''}" onclick="goToSlide(${i})"></div>`).join('');

  clearInterval(sliderTimer);
  sliderTimer = setInterval(() => goToSlide((sliderIdx+1) % count), 3500);
}

function goToSlide(n) {
  const slider = document.getElementById('main-slider');
  const dots = document.getElementById('slider-dots');
  sliderIdx = (n + slider.children.length) % slider.children.length;
  slider.style.transform = `translateX(-${sliderIdx*100}%)`;
  dots.querySelectorAll('.dot').forEach((d,i) => d.classList.toggle('active', i===sliderIdx));
}

function initMiniCarousel() {
  const slides = [
    {bg:'linear-gradient(135deg,#667eea,#764ba2)',cat:'Kurti Saree and Lehanga',title:'Kurti & Saree Sale',sub:'Starting ₹199!'},
    {bg:'linear-gradient(135deg,#f093fb,#f5576c)',cat:'Women Western',title:'Women Western Wear',sub:'Trendy & Affordable'},
    {bg:'linear-gradient(135deg,#4facfe,#00f2fe)',cat:'Electronics',title:'Electronics Deals',sub:'Up to 70% off'},
    {bg:'linear-gradient(135deg,#43e97b,#38f9d7)',cat:'Home and Kitchen',title:'Home & Kitchen',sub:'Make home beautiful'},
    {bg:'linear-gradient(135deg,#f7971e,#ffd200)',cat:'Beauty and Health',title:'Beauty Must-Haves',sub:'Glow every day'},
  ];
  document.getElementById('mini-carousel').innerHTML = slides.map(s => `
    <div class="mini-slide" style="background:${s.bg}" onclick="showCategory('${s.cat}')">
      <div class="mini-slide-text">
        <h3>${s.title}</h3>
        <p>${s.sub}</p>
        <button class="mini-shop-btn">SHOP NOW</button>
      </div>
    </div>`).join('');

  clearInterval(carouselTimer);
  carouselTimer = setInterval(() => {
    carouselIdx = (carouselIdx + 1) % slides.length;
    document.getElementById('mini-carousel').style.transform = `translateX(-${carouselIdx*100}%)`;
  }, 2800);
}

/* ============================================================
   COUNTDOWN TIMER
   ============================================================ */
function startCountdown() {
  let secs = 5*3600 + 23*60 + 47;
  clearInterval(countdownTimer);
  countdownTimer = setInterval(() => {
    if (secs <= 0) secs = 24*3600;
    secs--;
    document.getElementById('th').textContent = String(Math.floor(secs/3600)).padStart(2,'0');
    document.getElementById('tm').textContent = String(Math.floor((secs%3600)/60)).padStart(2,'0');
    document.getElementById('ts').textContent = String(secs%60).padStart(2,'0');
  }, 1000);
}

/* ============================================================
   NAVIGATION
   ============================================================ */
function showPage(pageId) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(pageId).classList.add('active');
  window.scrollTo(0,0);

  if (pageId !== currentPage) {
    pageHistory.push(pageId);
    currentPage = pageId;
  }

  // Update bottom nav
  const navMap = {'page-home':'nav-home','page-category':'nav-cat','page-cart':'nav-cart','page-track':'nav-track','page-account':'nav-acc'};
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  if (navMap[pageId]) document.getElementById(navMap[pageId]).classList.add('active');

  // Page-specific render
  if (pageId === 'page-cart') renderCart();
  if (pageId === 'page-wishlist') renderWishlist();
  if (pageId === 'page-checkout') { resetCheckout(); renderCheckoutStep(1); }
  if (pageId === 'page-account') checkUserSession();
}

function goBack() {
  if (pageHistory.length > 1) {
    pageHistory.pop();
    const prev = pageHistory[pageHistory.length-1];
    currentPage = prev;
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.getElementById(prev).classList.add('active');
    window.scrollTo(0,0);
  } else {
    showPage('page-home');
  }
}

function showCategory(name) {
  document.getElementById('cat-page-title').textContent = name === 'all' ? 'All Products' : name;
  const filtered = name === 'all' ? PRODUCTS : PRODUCTS.filter(p => p.category === name);
  currentCatProducts = filtered.length ? filtered : PRODUCTS;
  catOffset = 12;
  renderCategoryProducts(currentCatProducts.slice(0, catOffset));
  showPage('page-category');
}

function filterChip(el, cat) {
  document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  showCategory(cat);
}

function renderCategoryProducts(products) {
  document.getElementById('cat-products').innerHTML = products.map(p => productCard(p)).join('');
  document.getElementById('load-more-wrap').style.display = currentCatProducts.length > catOffset ? 'block' : 'none';
}

function loadMoreProducts() {
  catOffset += 8;
  renderCategoryProducts(currentCatProducts.slice(0, catOffset));
}

function sortCat(type, el) {
  document.querySelectorAll('.fc').forEach(f => f.classList.remove('active'));
  el.classList.add('active');
  let sorted = [...currentCatProducts];
  if (type === 'price-low') sorted.sort((a,b) => a.price - b.price);
  if (type === 'price-high') sorted.sort((a,b) => b.price - a.price);
  if (type === 'rating') sorted.sort((a,b) => b.rating - a.rating);
  if (type === 'newest') sorted.reverse();
  renderCategoryProducts(sorted.slice(0, catOffset));
}

function showFilterModal() {
  toast('Advanced filters coming soon!', 'warning');
}

/* ============================================================
   PRODUCT DETAIL
   ============================================================ */
function openProduct(id) {
  const p = PRODUCTS.find(x => x.id === id);
  if (!p) return;
  currentProduct = p;

  document.getElementById('d-main-img').src = p.img;
  document.getElementById('d-main-img').alt = p.name;
  document.getElementById('d-cat').textContent = p.category;
  document.getElementById('d-name').textContent = p.name;
  document.getElementById('d-rating').textContent = p.rating;
  document.getElementById('d-reviews').textContent = `${p.reviews.toLocaleString('en-IN')} reviews`;
  document.getElementById('d-price').textContent = `₹${p.price.toLocaleString('en-IN')}`;
  document.getElementById('d-orig').textContent = `₹${p.orig.toLocaleString('en-IN')}`;
  const disc = Math.round((p.orig - p.price)/p.orig*100);
  document.getElementById('d-disc').textContent = `${disc}% off`;

  // Thumbs (use same img as demo, real would have multiple)
  document.getElementById('d-thumbs').innerHTML = [p.img,p.img,p.img].map((img,i) => `
    <img src="${img}" class="d-thumb${i===0?' active':''}" onclick="changeThumb(this,'${img}')">
  `).join('');

  // Highlights
  if (p.highlights) {
    document.getElementById('d-highlights-list').innerHTML = p.highlights.map(h => `<li>${h}</li>`).join('');
  }

  // Delivery date
  const del = new Date(); del.setDate(del.getDate() + 5);
  document.getElementById('d-delivery').textContent = del.toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'short'});

  // Description
  document.getElementById('d-desc').textContent = p.desc;

  // Specs
  if (p.specs) {
    document.getElementById('d-specs-table').innerHTML = p.specs.map(([k,v]) => `
      <tr><td>${k}</td><td>${v}</td></tr>`).join('');
  }

  // Reviews
  document.getElementById('d-reviews-list').innerHTML = REVIEWS_DATA.slice(0,3).map(r => `
    <div style="border-bottom:1px solid var(--border);padding:12px 0">
      <div style="display:flex;gap:8px;align-items:center;margin-bottom:6px">
        <div style="width:32px;height:32px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-weight:800;color:var(--primary)">${r.name[0]}</div>
        <div><div style="font-size:13px;font-weight:700">${r.name}</div><div style="font-size:11px;color:var(--accent)">${'⭐'.repeat(r.rating)}</div></div>
      </div>
      <div style="font-size:13px;color:var(--text-muted)">${r.text}</div>
    </div>`).join('');

  // Similar
  const similar = PRODUCTS.filter(x => x.category === p.category && x.id !== p.id).slice(0,5);
  document.getElementById('d-similar').innerHTML = similar.map(s => productCard(s, true)).join('');

  // Wishlist btn
  document.getElementById('d-wish-btn').textContent = wishlist.includes(p.id) ? '❤️' : '🤍';

  // Clear pincode
  document.getElementById('pin-input').value = '';
  document.getElementById('pin-result').textContent = '';

  showPage('page-product');
}

function changeThumb(el, src) {
  document.getElementById('d-main-img').src = src;
  document.querySelectorAll('.d-thumb').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

function shareProduct() {
  if (navigator.share && currentProduct) {
    navigator.share({
      title: currentProduct.name,
      text: `${currentProduct.name} sirf ₹${currentProduct.price} mein! ShopIndia pe dekho:`,
      url: window.location.href
    }).catch(()=>{});
  } else {
    navigator.clipboard?.writeText(`${currentProduct?.name} sirf ₹${currentProduct?.price} mein ShopIndia pe!`);
    toast('Link copied! Share karo friends ke saath 🔗', 'success');
  }
}

function checkPincode() {
  const pin = document.getElementById('pin-input').value.trim();
  const result = document.getElementById('pin-result');
  if (pin.length !== 6 || isNaN(pin)) {
    result.textContent = '⚠️ Valid 6-digit pincode enter karo';
    result.className = 'pincode-result err';
    return;
  }
  if (CONFIG.serviceablePincodes.includes(pin)) {
    const days = Math.floor(Math.random()*3) + 4;
    result.textContent = `✅ Delivery available! Expected in ${days}–${days+1} days`;
    result.className = 'pincode-result ok';
  } else {
    result.textContent = '❌ Sorry, delivery not available to this pincode yet';
    result.className = 'pincode-result err';
  }
}

function addToCartCurrent() {
  if (!currentProduct) return;
  addToCart(currentProduct.id);
}

function buyNow() {
  if (!currentProduct) return;
  addToCart(currentProduct.id);
  showPage('page-cart');
}

function setReviewStar(n) {
  reviewStar = n;
  document.querySelectorAll('.star-opt').forEach((s,i) => s.classList.toggle('active', i < n));
}

function submitReview() {
  const name = document.getElementById('rv-name').value.trim();
  const text = document.getElementById('rv-text').value.trim();
  if (!name || !text || !reviewStar) { toast('Name, rating aur review sab bharo', 'error'); return; }
  // In production: POST to backend API
  toast('Review submit ho gaya! ⭐ Shukriya!', 'success');
  document.getElementById('rv-name').value = '';
  document.getElementById('rv-text').value = '';
  reviewStar = 0;
  document.querySelectorAll('.star-opt').forEach(s => s.classList.remove('active'));
}

/* ============================================================
   SEARCH
   ============================================================ */
function showSuggestions(val) {
  const el = document.getElementById('suggestions');
  if (!val || val.length < 2) { el.classList.remove('show'); return; }
  const matches = PRODUCTS.filter(p =>
    p.name.toLowerCase().includes(val.toLowerCase()) ||
    p.category.toLowerCase().includes(val.toLowerCase())
  ).slice(0,6);
  el.classList.add('show');
  el.innerHTML = matches.length
    ? matches.map(p => `
        <div class="suggestion-item" onclick="openProduct(${p.id});hideSuggestions()">
          <span>🔍</span>
          <span style="flex:1">${p.name}</span>
          <span style="color:var(--primary);font-weight:800">₹${p.price}</span>
        </div>`).join('')
    : `<div class="suggestion-item">No results found for "${val}"</div>`;
}

function hideSuggestions() {
  document.getElementById('suggestions').classList.remove('show');
}

function doSearch() {
  const val = document.getElementById('search-input').value.trim();
  if (!val) return;
  const filtered = PRODUCTS.filter(p =>
    p.name.toLowerCase().includes(val.toLowerCase()) ||
    p.category.toLowerCase().includes(val.toLowerCase())
  );
  document.getElementById('cat-page-title').textContent = `Results: "${val}"`;
  currentCatProducts = filtered.length ? filtered : PRODUCTS;
  catOffset = 12;
  renderCategoryProducts(currentCatProducts.slice(0, catOffset));
  showPage('page-category');
  hideSuggestions();
}

/* ============================================================
   CART
   ============================================================ */
function addToCart(id) {
  const p = PRODUCTS.find(x => x.id === id);
  if (!p) return;
  const existing = cart.find(i => i.id === id);
  if (existing) {
    existing.qty++;
  } else {
    cart.push({ id:p.id, name:p.name, price:p.price, orig:p.orig, img:p.img, qty:1, category:p.category });
  }
  saveCart();
  updateCartBadge();
  toast(`${p.name.slice(0,30)}... cart mein add! 🛒`, 'success');

  // ABANDONED CART TRACKING:
  // Flag this cart as "active" for abandoned cart emails
  // TODO: When user is logged in, sync cart to backend:
  // fetch('/api/cart/save', { method:'POST', body:JSON.stringify({userId, cart, timestamp}) })
  // Set a flag to trigger abandoned cart email if user doesn't checkout within 30 min
  localStorage.setItem('si-cart-updated-at', Date.now().toString());
}

function saveCart() {
  localStorage.setItem('si-cart', JSON.stringify(cart));
}

function updateCartBadge() {
  const total = cart.reduce((s,i) => s+i.qty, 0);
  document.getElementById('cart-count').textContent = total;
  const nb = document.getElementById('nav-cart-badge');
  if (total > 0) { nb.textContent = total; nb.style.display = 'flex'; }
  else nb.style.display = 'none';
}

function renderCart() {
  const el = document.getElementById('cart-body');
  document.getElementById('cart-item-count').textContent = `${cart.length} item${cart.length!==1?'s':''}`;

  if (cart.length === 0) {
    el.innerHTML = `
      <div class="empty-state">
        <div class="empty-icon">🛒</div>
        <h3>Cart khali hai!</h3>
        <p>Apne favourite products add karo</p>
        <button class="big-btn" onclick="showPage('page-home')">Shopping Start Karo</button>
      </div>`;
    return;
  }

  const subtotal = cart.reduce((s,i) => s + i.price*i.qty, 0);
  const shipping = subtotal >= CONFIG.freeShippingAbove ? 0 : CONFIG.standardShipping;
  const total = subtotal + shipping;

  el.innerHTML = cart.map(item => `
    <div class="cart-item">
      <img class="cart-item-img" src="${item.img}" alt="${item.name}">
      <div class="cart-item-info">
        <div class="ci-name">${item.name}</div>
        <div class="ci-price">₹${(item.price*item.qty).toLocaleString('en-IN')}</div>
        <div style="font-size:11px;color:var(--text-muted);margin-bottom:6px">₹${item.price} × ${item.qty}</div>
        <div class="qty-row">
          <button class="qty-btn" onclick="changeQty(${item.id},-1)">−</button>
          <span class="qty-num">${item.qty}</span>
          <button class="qty-btn" onclick="changeQty(${item.id},1)">+</button>
          <button class="del-btn" onclick="removeCartItem(${item.id})">🗑️</button>
        </div>
      </div>
    </div>`).join('') + `
    <div class="cart-summary">
      <div style="font-size:13px;font-weight:800;margin-bottom:10px">💰 Price Details</div>
      <div class="coupon-row" style="margin-bottom:12px">
        <input type="text" id="cart-coupon" placeholder="COUPON CODE" style="text-transform:uppercase">
        <button onclick="applyCouponCart()">Apply</button>
      </div>
      <div class="sum-row"><span>Subtotal (${cart.reduce((s,i)=>s+i.qty,0)} items)</span><span>₹${subtotal.toLocaleString('en-IN')}</span></div>
      <div class="sum-row"><span>Delivery</span><span style="color:${shipping===0?'var(--success)':'inherit'}">${shipping===0?'FREE':'₹'+shipping}</span></div>
      ${shipping > 0 ? `<div style="font-size:11px;color:var(--primary);margin:-6px 0 8px">Add ₹${CONFIG.freeShippingAbove-subtotal} more for FREE delivery</div>`:''}
      <div class="sum-row total"><span>Total</span><span>₹${total.toLocaleString('en-IN')}</span></div>
    </div>
    <div style="padding:14px">
      <button class="checkout-btn" onclick="showPage('page-checkout')">Proceed to Checkout →</button>
      <div style="text-align:center;margin-top:10px;font-size:11px;color:var(--text-muted)">🔒 Safe & Secure Checkout · UPI & COD available</div>
    </div>`;
}

function changeQty(id, delta) {
  const item = cart.find(i => i.id === id);
  if (!item) return;
  item.qty = Math.max(0, item.qty + delta);
  if (item.qty === 0) cart = cart.filter(i => i.id !== id);
  saveCart();
  updateCartBadge();
  renderCart();
}

function removeCartItem(id) {
  cart = cart.filter(i => i.id !== id);
  saveCart();
  updateCartBadge();
  renderCart();
  toast('Item removed from cart');
}

function applyCouponCart() {
  const code = document.getElementById('cart-coupon').value.trim().toUpperCase();
  const coupon = CONFIG.coupons[code];
  if (!coupon) { toast('Invalid coupon code', 'error'); return; }
  const subtotal = cart.reduce((s,i) => s+i.price*i.qty, 0);
  if (subtotal < coupon.minOrder) { toast(`Minimum order ₹${coupon.minOrder} needed`, 'error'); return; }
  appliedCoupon = { code, ...coupon };
  toast(`Coupon applied! ${coupon.desc} 🎉`, 'success');
  renderCart();
}

/* ============================================================
   WISHLIST
   ============================================================ */
function toggleWishItem(id, btn) {
  if (wishlist.includes(id)) {
    wishlist = wishlist.filter(x => x !== id);
    if (btn) btn.textContent = '🤍';
    toast('Wishlist se remove kiya');
  } else {
    wishlist.push(id);
    if (btn) btn.textContent = '❤️';
    toast('Wishlist mein add! ❤️', 'success');
  }
  localStorage.setItem('si-wishlist', JSON.stringify(wishlist));
}

function toggleWishlistCurrent() {
  if (!currentProduct) return;
  toggleWishItem(currentProduct.id);
  document.getElementById('d-wish-btn').textContent = wishlist.includes(currentProduct.id) ? '❤️' : '🤍';
}

function renderWishlist() {
  const el = document.getElementById('wishlist-body');
  const items = PRODUCTS.filter(p => wishlist.includes(p.id));
  if (!items.length) {
    el.innerHTML = `
      <div class="empty-state">
        <div class="empty-icon">❤️</div>
        <h3>Wishlist khali hai!</h3>
        <p>Products save karo baad mein khareedne ke liye</p>
        <button class="big-btn" onclick="showPage('page-home')">Products Explore Karo</button>
      </div>`;
    return;
  }
  el.innerHTML = `<div class="products-grid">${items.map(p => productCard(p)).join('')}</div>`;
}

/* ============================================================
   CHECKOUT STEPS
   ============================================================ */
function resetCheckout() {
  selectedShipping = 'standard';
  selectedPayment = 'upi';
  appliedCoupon = null;
}

function updateStepUI(step) {
  [1,2,3,4].forEach(i => {
    document.getElementById(`sn${i}`).className = 'step-num' + (i<step?' done':i===step?' active':'');
    document.getElementById(`sl${i}`).className = 'step-label' + (i===step?' active':'');
  });
  [1,2,3].forEach(i => {
    document.getElementById(`ss${i}`).className = 'step-sep' + (i<step?' done':'');
  });
  ['co-step1','co-step2','co-step3','co-step4'].forEach((id,idx) => {
    document.getElementById(id).style.display = idx+1===step ? 'block' : 'none';
  });
}

function renderCheckoutStep(step) {
  updateStepUI(step);
  if (step === 2) renderStep2();
  if (step === 4) renderStep4();
}

function coGoStep(step) { renderCheckoutStep(step); }

function checkoutStep1() {
  const name = document.getElementById('co-name').value.trim();
  const phone = document.getElementById('co-phone').value.trim();
  const address = document.getElementById('co-address').value.trim();
  const city = document.getElementById('co-city').value.trim();
  const pin = document.getElementById('co-pin').value.trim();
  const state = document.getElementById('co-state').value;
  let valid = true;

  const validate = (fgId, cond) => {
    const fg = document.getElementById(fgId);
    if (!cond) { fg.classList.add('has-error'); valid = false; }
    else fg.classList.remove('has-error');
  };
  validate('fg-name', name.length >= 2);
  validate('fg-phone', phone.length === 10 && /^\d+$/.test(phone));
  validate('fg-address', address.length >= 5);
  validate('fg-city', city.length >= 2);
  validate('fg-pin', pin.length === 6 && /^\d+$/.test(pin));
  validate('fg-state', state !== '');
  if (!valid) { toast('Please fill all required fields correctly', 'error'); return; }
  renderCheckoutStep(2);
}

function renderStep2() {
  const subtotal = cart.reduce((s,i) => s+i.price*i.qty, 0);
  const baseShipping = subtotal >= CONFIG.freeShippingAbove ? 0 : CONFIG.standardShipping;
  document.getElementById('ship-std-price').textContent = baseShipping === 0 ? 'FREE' : `₹${baseShipping}`;

  // Items
  document.getElementById('co-items-list').innerHTML = cart.map(i => `
    <div style="display:flex;gap:10px;align-items:center;margin-bottom:10px;padding-bottom:10px;border-bottom:1px solid var(--border)">
      <img src="${i.img}" style="width:48px;height:48px;border-radius:8px;object-fit:cover">
      <div style="flex:1"><div style="font-size:13px;font-weight:700">${i.name.slice(0,40)}</div><div style="font-size:11px;color:var(--text-muted)">Qty: ${i.qty}</div></div>
      <div style="font-weight:800">₹${(i.price*i.qty).toLocaleString('en-IN')}</div>
    </div>`).join('');

  calcTotals();
}

function calcTotals() {
  const subtotal = cart.reduce((s,i) => s+i.price*i.qty, 0);
  let shipping = subtotal >= CONFIG.freeShippingAbove ? 0 : CONFIG.standardShipping;
  if (selectedShipping === 'express') shipping += CONFIG.expressShipping;
  let discount = 0;
  if (appliedCoupon) {
    if (appliedCoupon.type === 'percent') discount = Math.floor(subtotal * appliedCoupon.value / 100);
    else discount = appliedCoupon.value;
    if (appliedCoupon.value === 49) shipping = 0; // free shipping coupon
  }
  const gst = Math.round((subtotal - discount) * CONFIG.gstRate);
  const total = subtotal + shipping - discount + gst;

  const fmt = n => `₹${n.toLocaleString('en-IN')}`;
  ['co-subtotal','rv-subtotal'].forEach(id => { if(document.getElementById(id)) document.getElementById(id).textContent = fmt(subtotal); });
  ['co-ship','rv-ship'].forEach(id => { if(document.getElementById(id)) document.getElementById(id).textContent = shipping===0?'FREE':fmt(shipping); });
  ['co-gst','rv-gst'].forEach(id => { if(document.getElementById(id)) document.getElementById(id).textContent = fmt(gst); });
  ['co-disc','rv-disc'].forEach(id => { if(document.getElementById(id)) document.getElementById(id).textContent = discount>0?`-${fmt(discount)}`:'—'; });
  ['co-total','rv-total'].forEach(id => { if(document.getElementById(id)) document.getElementById(id).textContent = fmt(total); });

  return { subtotal, shipping, discount, gst, total };
}

function selectShipping(type) {
  selectedShipping = type;
  document.getElementById('ship-standard').classList.toggle('selected', type==='standard');
  document.getElementById('ship-express').classList.toggle('selected', type==='express');
  document.getElementById('sr-standard').innerHTML = type==='standard'?'<div style="width:10px;height:10px;border-radius:50%;background:var(--primary)"></div>':'';
  document.getElementById('sr-express').innerHTML = type==='express'?'<div style="width:10px;height:10px;border-radius:50%;background:var(--primary)"></div>':'';
  calcTotals();
}

function applyCoupon() {
  const code = document.getElementById('co-coupon').value.trim().toUpperCase();
  const coupon = CONFIG.coupons[code];
  const subtotal = cart.reduce((s,i) => s+i.price*i.qty, 0);
  const msgEl = document.getElementById('coupon-msg');
  if (!coupon) { msgEl.style.color='var(--danger)'; msgEl.textContent='❌ Invalid coupon code'; return; }
  if (subtotal < coupon.minOrder) { msgEl.style.color='var(--danger)'; msgEl.textContent=`❌ Min order ₹${coupon.minOrder} required`; return; }
  appliedCoupon = { code, ...coupon };
  msgEl.style.color='var(--success)'; msgEl.textContent=`✅ "${code}" applied! ${coupon.desc}`;
  calcTotals();
}

function checkoutStep2() {
  renderCheckoutStep(3);
}

function selectPayment(type) {
  selectedPayment = type;
  ['upi','cod','card','netbanking'].forEach(t => {
    document.getElementById(`pay-${t}`).classList.toggle('selected', t===type);
    const r = document.getElementById(`pr-${t}`);
    r.innerHTML = t===type?'<div style="width:10px;height:10px;border-radius:50%;background:var(--primary)"></div>':'';
  });
}

function checkoutStep3() {
  renderCheckoutStep(4);
}

function renderStep4() {
  const name = document.getElementById('co-name').value;
  const phone = document.getElementById('co-phone').value;
  const address = document.getElementById('co-address').value;
  const city = document.getElementById('co-city').value;
  const state = document.getElementById('co-state').value;
  const pin = document.getElementById('co-pin').value;

  document.getElementById('review-address').innerHTML = `
    <strong>${name}</strong><br>
    +91 ${phone}<br>
    ${address}, ${city}<br>
    ${state} - ${pin}`;

  document.getElementById('review-items').innerHTML = cart.map(i => `
    <div style="display:flex;gap:10px;align-items:center;margin-bottom:10px">
      <img src="${i.img}" style="width:42px;height:42px;border-radius:8px;object-fit:cover">
      <div style="flex:1;font-size:13px;font-weight:700">${i.name.slice(0,40)}</div>
      <div style="font-weight:800">₹${(i.price*i.qty).toLocaleString('en-IN')}</div>
    </div>`).join('');

  const payNames = {upi:'📲 UPI Payment',cod:'💵 Cash on Delivery',card:'💳 Debit/Credit Card',netbanking:'🏦 Net Banking'};
  document.getElementById('review-payment').textContent = payNames[selectedPayment];
  calcTotals();
}

function placeOrder() {
  const { subtotal, shipping, discount, gst, total } = calcTotals();
  pendingOrder = {
    name: document.getElementById('co-name').value,
    phone: document.getElementById('co-phone').value,
    email: document.getElementById('co-email').value,
    address: document.getElementById('co-address').value,
    city: document.getElementById('co-city').value,
    state: document.getElementById('co-state').value,
    pin: document.getElementById('co-pin').value,
    items: [...cart], subtotal, shipping, discount, gst, total,
    paymentMethod: selectedPayment,
    shippingMethod: selectedShipping,
    coupon: appliedCoupon?.code || null,
  };

  if (selectedPayment === 'upi') {
    document.getElementById('upi-amount').textContent = `₹${total.toLocaleString('en-IN')}`;
    showPage('page-payment');
  } else if (selectedPayment === 'cod') {
    // Render COD summary
    document.getElementById('cod-total').textContent = `₹${total.toLocaleString('en-IN')}`;
    document.getElementById('cod-summary').innerHTML = `
      <div class="sum-row"><span>Subtotal</span><span>₹${subtotal.toLocaleString('en-IN')}</span></div>
      <div class="sum-row"><span>Shipping</span><span>${shipping===0?'FREE':'₹'+shipping}</span></div>
      <div class="sum-row"><span>GST</span><span>₹${gst.toLocaleString('en-IN')}</span></div>`;
    showPage('page-cod');
  } else {
    // Card / Netbanking - redirect to Razorpay (see comment below)
    // RAZORPAY INTEGRATION:
    // const options = {
    //   key: process.env.RAZORPAY_KEY_ID, // Add to CONFIG
    //   amount: total * 100, // in paise
    //   currency: 'INR',
    //   name: CONFIG.storeName,
    //   description: `Order from ${CONFIG.storeName}`,
    //   handler: function(response) { finaliseOrder(response.razorpay_payment_id); },
    //   prefill: { name: pendingOrder.name, contact: '+91'+pendingOrder.phone }
    // };
    // new Razorpay(options).open();
    toast('Card/Netbanking: Razorpay integration ready. Add your key in CONFIG.', 'warning');
  }
}

/* ============================================================
   ORDER PLACEMENT
   ============================================================ */
function confirmUPIOrder() {
  const file = document.getElementById('ss-upload').files[0];
  if (!file) { toast('Payment screenshot upload karo', 'error'); return; }
  finaliseOrder('UPI-SCREENSHOT');
}

function confirmCODOrder() {
  finaliseOrder('COD');
}

function handleScreenshot(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      document.getElementById('ss-preview').innerHTML = `
        <img src="${e.target.result}" style="width:100%;border-radius:10px;max-height:200px;object-fit:contain;margin-top:8px">
        <div style="font-size:12px;color:var(--success);margin-top:6px;font-weight:700">✅ Screenshot uploaded</div>`;
    };
    reader.readAsDataURL(input.files[0]);
  }
}

function copyUPI() {
  navigator.clipboard?.writeText(CONFIG.upiId);
  toast('UPI ID copied! 📋', 'success');
}

function finaliseOrder(paymentRef) {
  const orderId = 'SI-' + Date.now().toString().slice(-6);

  // Save order to localStorage (in production: POST to backend API)
  // EMAIL TEMPLATES: After saving, trigger:
  // - sendOrderConfirmationEmail(pendingOrder.email, orderId) → see /backend/emails/order-confirmation.html
  // - sendAdminNotification(orderId) → your admin email
  // - sendWhatsAppMessage(pendingOrder.phone, orderId) → WhatsApp Business API
  const orderData = {
    id: orderId,
    ...pendingOrder,
    paymentRef,
    status: pendingOrder.paymentMethod === 'cod' ? 'Confirmed (COD)' : 'Payment Verification Pending',
    createdAt: new Date().toISOString(),
    // Supplier info (for dropshipping workflow):
    supplierInfo: pendingOrder.items.map(item => {
      const product = PRODUCTS.find(p => p.id === item.id);
      return {
        productId: item.id, productName: item.name, qty: item.qty,
        supplier: product?.supplier || 'Unknown',
        supplierSku: product?.supplierSku || 'N/A',
        handlingDays: product?.handlingDays || 2,
      };
    }),
  };

  const orders = JSON.parse(localStorage.getItem('si-orders') || '[]');
  orders.push(orderData);
  localStorage.setItem('si-orders', JSON.stringify(orders));

  // Also POST to backend
  // fetch('/api/orders', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(orderData) })
  //   .catch(err => console.error('Backend save failed:', err));

  // Clear cart
  cart = [];
  saveCart();
  updateCartBadge();

  // Clear abandoned cart flag
  localStorage.removeItem('si-cart-updated-at');

  document.getElementById('success-order-id').textContent = orderId;
  showPage('page-success');
  toast('Order placed! 🎉', 'success');
}

function whatsappOrder() {
  const orderId = document.getElementById('success-order-id').textContent;
  window.open(`https://wa.me/${CONFIG.whatsapp}?text=Hi! I placed order ${orderId} on ShopIndia. Please help with tracking.`, '_blank');
}

/* ============================================================
   ORDER TRACKING
   ============================================================ */
function trackOrder() {
  const orderId = document.getElementById('track-id').value.trim().toUpperCase();
  const phone = document.getElementById('track-phone').value.trim();
  if (!orderId || !phone) { toast('Order ID aur phone dono bharo', 'error'); return; }

  const orders = JSON.parse(localStorage.getItem('si-orders') || '[]');
  const order = orders.find(o => o.id === orderId && o.phone === phone);
  const result = document.getElementById('track-result');
  result.style.display = 'block';

  if (!order) {
    result.innerHTML = `
      <div class="empty-state" style="padding:30px 20px">
        <div class="empty-icon">🔍</div>
        <h3>Order nahi mila</h3>
        <p>Order ID aur phone number dobara check karo</p>
      </div>`;
    return;
  }

  const statuses = ['Order Placed','Payment Verified','Processing','Shipped','Out for Delivery','Delivered'];
  const curIdx = statuses.indexOf(order.status) !== -1
    ? statuses.indexOf(order.status)
    : order.status.includes('Verification') ? 0 : order.status.includes('COD') ? 1 : 0;

  result.innerHTML = `
    <div style="background:white;border-radius:var(--radius);padding:16px;box-shadow:var(--shadow)">
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <div style="font-size:17px;font-weight:900">${order.id}</div>
        <div class="order-status status-${order.status.toLowerCase().includes('deliver')?'delivered':order.status.toLowerCase().includes('ship')?'shipped':'pending'}">${order.status}</div>
      </div>
      <div style="font-size:12px;color:var(--text-muted);margin-bottom:16px">
        ${order.items?.length||0} items · ₹${order.total?.toLocaleString('en-IN')} · ${new Date(order.createdAt).toLocaleDateString('en-IN')}
      </div>
      <div class="track-steps">
        ${statuses.map((s,i) => `
          <div class="track-step">
            <div class="ts-line">
              <div class="ts-dot${i<curIdx?' done':i===curIdx?' now':' wait'}"></div>
              ${i<statuses.length-1?`<div class="ts-connector${i<curIdx?' done':' wait'}"></div>`:''}
            </div>
            <div class="ts-info" style="color:${i<=curIdx?'var(--text)':'var(--text-muted)'}">
              <div class="ts-title">${s}</div>
              <div class="ts-desc">${['Order received & being verified','Payment confirmed & processing','Packed & ready to dispatch','Package dispatched via courier','Out for last mile delivery','Delivered to your doorstep'][i]}</div>
              ${i===curIdx?`<div class="ts-date">Current Status</div>`:''}
            </div>
          </div>`).join('')}
      </div>
      <button class="wa-order-btn" onclick="window.open('https://wa.me/${CONFIG.whatsapp}?text=Track order ${order.id}','_blank')" style="margin-top:12px">💬 WhatsApp Support</button>
    </div>`;
}

/* ============================================================
   ACCOUNT / AUTH
   ============================================================ */
function checkUserSession() {
  if (currentUser) {
    document.getElementById('acc-guest').style.display = 'none';
    document.getElementById('acc-profile').style.display = 'block';
    document.getElementById('acc-name').textContent = currentUser.name;
    document.getElementById('acc-phone').textContent = '+91 ' + currentUser.phone;
  } else {
    document.getElementById('acc-guest').style.display = 'block';
    document.getElementById('acc-profile').style.display = 'none';
  }
}

function loginUser() {
  const phone = document.getElementById('l-phone').value.trim();
  const name = document.getElementById('l-name').value.trim() || 'Valued Customer';
  if (phone.length !== 10 || !/^\d+$/.test(phone)) { toast('Valid 10-digit mobile number enter karo', 'error'); return; }
  // In production: send OTP via SMS (Msg91, Exotel, etc.)
  // TODO: const otpRes = await fetch('/api/auth/send-otp', { method:'POST', body:JSON.stringify({phone}) })
  currentUser = { name, phone, createdAt: new Date().toISOString() };
  localStorage.setItem('si-user', JSON.stringify(currentUser));
  checkUserSession();
  toast(`Welcome, ${name}! 🎉`, 'success');
}

function logoutUser() {
  if (!confirm('Logout karna chahte ho?')) return;
  currentUser = null;
  localStorage.removeItem('si-user');
  checkUserSession();
  toast('Logged out');
}

function showMyOrders() {
  const orders = JSON.parse(localStorage.getItem('si-orders') || '[]');
  const el = document.getElementById('my-orders-list');
  if (!orders.length) {
    el.innerHTML = '<div style="text-align:center;padding:24px;color:var(--text-muted)">Abhi tak koi order nahi</div>';
    return;
  }
  el.innerHTML = `<div style="padding:14px 14px 8px;font-size:16px;font-weight:800">📦 My Orders</div>` +
    [...orders].reverse().map(o => `
      <div class="order-card">
        <div class="order-card-header">
          <div class="order-id">${o.id}</div>
          <div class="order-status status-${o.status?.toLowerCase().includes('deliver')?'delivered':o.status?.toLowerCase().includes('ship')?'shipped':o.status?.toLowerCase().includes('cod')?'confirmed':'pending'}">${o.status||'Processing'}</div>
        </div>
        <div class="order-card-body">${o.items?.length||0} items · ₹${o.total?.toLocaleString('en-IN')} · ${new Date(o.createdAt).toLocaleDateString('en-IN')}</div>
        <div class="order-card-footer">
          <button class="oc-btn" onclick="showPage('page-track')">Track</button>
          <button class="oc-btn primary" onclick="window.open('https://wa.me/${CONFIG.whatsapp}?text=Help with order ${o.id}','_blank')">WhatsApp</button>
        </div>
      </div>`).join('');
}

/* ============================================================
   NEWSLETTER & CONTACT
   ============================================================ */
function subscribeNewsletter() {
  const phone = document.getElementById('nl-phone').value.trim();
  if (phone.length !== 10) { toast('Valid WhatsApp number enter karo', 'error'); return; }
  // In production: POST to backend for newsletter list
  // fetch('/api/subscribe', { method:'POST', body:JSON.stringify({phone}) })
  toast('Subscribed! Exclusive deals aayenge WhatsApp pe 🎉', 'success');
  document.getElementById('nl-phone').value = '';
}

function sendContactMsg() {
  const name = document.getElementById('c-name').value.trim();
  const phone = document.getElementById('c-phone').value.trim();
  const msg = document.getElementById('c-msg').value.trim();
  if (!name || !phone || !msg) { toast('Sab fields fill karo', 'error'); return; }
  // In production: POST to backend or send WhatsApp
  window.open(`https://wa.me/${CONFIG.whatsapp}?text=Hi! My name is ${name} (${phone}). ${msg}`, '_blank');
  toast('Redirecting to WhatsApp... 💬', 'success');
}

/* ============================================================
   UTILS
   ============================================================ */
function toast(msg, type='') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (type?' '+type:'');
  clearTimeout(t._timeout);
  t._timeout = setTimeout(() => t.classList.remove('show'), 3000);
}
</script>
</body>
</html>
