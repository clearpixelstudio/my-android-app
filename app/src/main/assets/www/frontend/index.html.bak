<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#f43f5e">
<meta name="description" content="ShopIndia - India ka sabse trusted dropshipping store. Fashion, Electronics, Beauty, Home aur bahut kuch ₹99 se shuru.">
<meta name="keywords" content="online shopping india, kurti, saree, electronics, beauty, home decor, dropshipping">
<meta property="og:title" content="ShopIndia - Shop Smart, Save More">
<meta property="og:description" content="Trending products at best prices. Free delivery on ₹499+. COD available.">
<meta property="og:type" content="website">
<meta property="og:image" content="https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?w=1200&q=80">
<title>ShopIndia - Shop Smart, Save More 🛍️</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&family=Baloo+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ===== CONFIG - Change colors here ===== */
:root {
  --primary: #f43f5e;
  --primary-dark: #e11d48;
  --primary-light: #fecdd3;
  --secondary: #6366f1;
  --accent: #f59e0b;
  --success: #10b981;
  --warning: #f59e0b;
  --danger: #ef4444;
  --text: #1e293b;
  --text-muted: #64748b;
  --bg: #f8fafc;
  --card: #ffffff;
  --border: #e2e8f0;
  --radius: 14px;
  --radius-sm: 8px;
  --shadow: 0 2px 12px rgba(0,0,0,0.07);
  --shadow-md: 0 6px 24px rgba(0,0,0,0.12);
  --font: 'Nunito', sans-serif;
  --font-display: 'Baloo 2', cursive;
  /* Business Config */
  --upi-id: 'tanvir786@ptaxis';
  --whatsapp: '917866048085';
  --free-shipping-above: 499;
  --shipping-charge: 49;
}

/* ===== RESET ===== */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
html { scroll-behavior:smooth; font-size:16px; }
body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  max-width: 480px;
  margin: 0 auto;
  min-height: 100vh;
  overflow-x: hidden;
  position: relative;
}

/* ===== TYPOGRAPHY ===== */
h1 { font-family: var(--font-display); font-size: 24px; font-weight: 800; }
h2 { font-size: 20px; font-weight: 800; }
h3 { font-size: 16px; font-weight: 700; }
p { font-size: 14px; line-height: 1.6; }

/* ===== HEADER ===== */
.header {
  position: sticky; top: 0; z-index: 200;
  background: linear-gradient(135deg, #f43f5e 0%, #e11d48 100%);
  padding: 10px 14px 8px;
  box-shadow: 0 3px 15px rgba(244,63,94,0.35);
}
.header-top { display:flex; align-items:center; gap:8px; margin-bottom:9px; }
.logo { color:white; font-family:var(--font-display); font-size:24px; font-weight:800; flex:1; letter-spacing:-0.5px; cursor:pointer; }
.logo em { color:#ffd700; font-style:normal; }
.logo sup { font-size:10px; color:rgba(255,255,255,0.7); font-family:var(--font); font-weight:600; vertical-align:super; }
.header-icons { display:flex; gap:8px; }
.icon-btn {
  background:rgba(255,255,255,0.2);
  border:none; color:white;
  width:38px; height:38px;
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  cursor:pointer; font-size:17px;
  position:relative; transition:background 0.2s;
  backdrop-filter:blur(4px);
}
.icon-btn:active { background:rgba(255,255,255,0.35); }
.badge {
  position:absolute; top:-4px; right:-4px;
  background:#ffd700; color:#1e293b;
  font-size:9px; font-weight:900;
  width:17px; height:17px;
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  border:2px solid #e11d48;
}
.search-wrap { position:relative; }
.search-bar {
  display:flex;
  background:white;
  border-radius:12px;
  overflow:hidden;
  box-shadow:0 2px 8px rgba(0,0,0,0.15);
}
.search-bar input {
  flex:1; border:none; outline:none;
  padding:10px 14px; font-size:13px;
  font-family:var(--font); color:var(--text);
}
.search-bar button {
  background:var(--accent); border:none;
  padding:10px 16px; color:white;
  cursor:pointer; font-size:15px;
  transition:background 0.2s;
}
.search-bar button:active { background:#d97706; }
.search-suggestions {
  position:absolute; top:calc(100% + 4px); left:0; right:0;
  background:white; border-radius:12px;
  box-shadow:var(--shadow-md); z-index:300;
  max-height:220px; overflow-y:auto;
  display:none; border:1px solid var(--border);
}
.search-suggestions.show { display:block; }
.suggestion-item {
  padding:11px 16px; font-size:13px;
  cursor:pointer; border-bottom:1px solid var(--border);
  display:flex; align-items:center; gap:10px;
  transition:background 0.15s;
}
.suggestion-item:last-child { border-bottom:none; }
.suggestion-item:hover { background:var(--bg); }

/* ===== CATEGORY CHIPS ===== */
.cat-chips {
  display:flex; gap:8px; overflow-x:auto;
  padding:10px 14px;
  background:white; border-bottom:1px solid var(--border);
  scrollbar-width:none; position:sticky; top:106px; z-index:100;
}
.cat-chips::-webkit-scrollbar { display:none; }
.chip {
  flex-shrink:0; padding:6px 15px;
  border-radius:20px; font-size:12px; font-weight:700;
  cursor:pointer; border:1.5px solid var(--border);
  color:var(--text-muted); white-space:nowrap;
  transition:all 0.2s;
}
.chip.active, .chip:hover { background:var(--primary); color:white; border-color:var(--primary); }

/* ===== HERO SLIDER ===== */
.slider-wrap { position:relative; overflow:hidden; background:white; }
.slider { display:flex; transition:transform 0.45s cubic-bezier(.4,0,.2,1); }
.slide {
  min-width:100%; height:185px;
  position:relative; overflow:hidden;
  display:flex; align-items:center;
}
.slide-bg {
  position:absolute; inset:0;
  background-size:cover; background-position:center;
}
.slide-overlay {
  position:absolute; inset:0;
  background:linear-gradient(100deg, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.1) 70%);
}
.slide-content {
  position:relative; z-index:2;
  padding:20px;
}
.slide-tag {
  background:var(--accent); color:white;
  font-size:10px; font-weight:900;
  padding:3px 9px; border-radius:5px;
  width:fit-content; margin-bottom:7px;
  letter-spacing:0.5px;
}
.slide-title {
  color:white; font-family:var(--font-display);
  font-size:20px; font-weight:800;
  line-height:1.2; margin-bottom:5px;
}
.slide-sub { color:rgba(255,255,255,0.85); font-size:12px; margin-bottom:12px; }
.slide-btn {
  background:white; color:var(--primary);
  font-size:12px; font-weight:800;
  padding:7px 16px; border-radius:20px;
  border:none; cursor:pointer;
  box-shadow:0 2px 8px rgba(0,0,0,0.2);
  font-family:var(--font);
}
.slider-dots {
  display:flex; justify-content:center;
  gap:5px; padding:8px;
  background:white;
}
.dot {
  width:6px; height:6px;
  border-radius:50%; background:var(--border);
  transition:all 0.3s; cursor:pointer;
}
.dot.active { background:var(--primary); width:20px; border-radius:3px; }

/* ===== TRUST BADGES ===== */
.trust-row {
  display:flex; overflow-x:auto; gap:8px;
  padding:10px 14px; background:white;
  scrollbar-width:none; border-top:1px solid var(--border);
}
.trust-row::-webkit-scrollbar { display:none; }
.trust-badge {
  flex-shrink:0; display:flex; align-items:center; gap:7px;
  background:#f0fdf4; border:1px solid #bbf7d0;
  border-radius:10px; padding:8px 12px;
}
.trust-badge .t-icon { font-size:17px; }
.trust-badge .t-text { font-size:10px; font-weight:700; color:#166534; white-space:nowrap; line-height:1.3; }

/* ===== SECTIONS ===== */
.divider { height:8px; background:var(--bg); }
.section { padding:14px; }
.section-header {
  display:flex; align-items:center;
  justify-content:space-between; margin-bottom:12px;
}
.section-title {
  font-family:var(--font-display);
  font-size:17px; font-weight:800; color:var(--text);
}
.see-all {
  font-size:12px; color:var(--primary);
  font-weight:700; cursor:pointer;
  display:flex; align-items:center; gap:3px;
}

/* ===== CATEGORY GRID ===== */
.cat-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; }
.cat-item {
  display:flex; flex-direction:column;
  align-items:center; gap:6px; cursor:pointer;
}
.cat-icon {
  width:62px; height:62px; border-radius:18px;
  display:flex; align-items:center; justify-content:center;
  font-size:26px; box-shadow:var(--shadow);
  transition:transform 0.2s;
}
.cat-item:active .cat-icon { transform:scale(0.92); }
.cat-name { font-size:10px; font-weight:700; text-align:center; color:var(--text); line-height:1.2; }

/* ===== PRODUCT CARDS ===== */
.products-scroll { display:flex; gap:10px; overflow-x:auto; padding-bottom:4px; scrollbar-width:none; }
.products-scroll::-webkit-scrollbar { display:none; }
.products-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:10px; }

.product-card {
  background:var(--card); border-radius:var(--radius);
  overflow:hidden; box-shadow:var(--shadow);
  cursor:pointer; transition:transform 0.2s, box-shadow 0.2s;
  flex-shrink:0; position:relative;
}
.product-card.scroll-card { width:158px; }
.product-card:active { transform:scale(0.97); box-shadow:var(--shadow-md); }
.product-img { position:relative; overflow:hidden; }
.product-img img {
  width:100%; height:158px; object-fit:cover;
  display:block; transition:transform 0.3s;
}
.product-card:hover .product-img img { transform:scale(1.04); }
.product-img .p-badge {
  position:absolute; top:8px; left:8px;
  background:var(--primary); color:white;
  font-size:10px; font-weight:900;
  padding:2px 8px; border-radius:5px;
}
.product-img .p-badge.green { background:var(--success); }
.product-img .p-wishlist {
  position:absolute; top:8px; right:8px;
  background:rgba(255,255,255,0.9);
  border:none; width:30px; height:30px;
  border-radius:50%; display:flex;
  align-items:center; justify-content:center;
  font-size:15px; cursor:pointer;
  box-shadow:var(--shadow); transition:all 0.2s;
  backdrop-filter:blur(4px);
}
.product-img .p-wishlist.active { background:var(--primary); }
.product-info { padding:10px; }
.product-name {
  font-size:12px; font-weight:700; color:var(--text);
  margin-bottom:4px;
  display:-webkit-box; -webkit-line-clamp:2;
  -webkit-box-orient:vertical; overflow:hidden;
  line-height:1.35;
}
.product-rating { display:flex; align-items:center; gap:3px; margin-bottom:5px; }
.p-stars { font-size:10px; color:var(--accent); }
.p-rcount { font-size:10px; color:var(--text-muted); }
.product-price { display:flex; align-items:baseline; gap:5px; flex-wrap:wrap; }
.p-current { font-size:15px; font-weight:900; color:var(--primary); }
.p-orig { font-size:11px; color:var(--text-muted); text-decoration:line-through; }
.p-off { font-size:11px; font-weight:700; color:var(--success); }
.p-add-btn {
  width:100%; margin-top:8px;
  background:var(--primary-light);
  color:var(--primary); border:none;
  border-radius:7px; padding:7px;
  font-size:12px; font-weight:800;
  cursor:pointer; font-family:var(--font);
  transition:background 0.2s;
}
.p-add-btn:active { background:var(--primary); color:white; }

/* ===== OFFER TIMER ===== */
.offer-strip {
  background:linear-gradient(135deg,#ff6b35,#f7c59f);
  padding:12px 14px;
  display:flex; align-items:center; gap:10px;
}
.offer-strip h3 { color:white; font-size:14px; font-weight:800; flex:1; }
.timer-boxes { display:flex; align-items:center; gap:4px; }
.t-box {
  background:rgba(0,0,0,0.3);
  color:white; border-radius:6px;
  padding:4px 8px; font-size:15px;
  font-weight:900; font-variant-numeric:tabular-nums;
  min-width:32px; text-align:center;
}
.t-sep { color:white; font-weight:900; }

/* ===== MALL / BANNER ===== */
.mall-banner {
  background:linear-gradient(135deg,#667eea,#764ba2);
  padding:16px 14px; margin:0;
}
.mall-title { color:white; font-family:var(--font-display); font-size:19px; font-weight:800; margin-bottom:3px; }
.mall-sub { color:rgba(255,255,255,0.8); font-size:12px; margin-bottom:14px; }
.mall-cats { display:flex; gap:12px; overflow-x:auto; scrollbar-width:none; margin-bottom:14px; }
.mall-cats::-webkit-scrollbar { display:none; }
.mall-cat { flex-shrink:0; text-align:center; cursor:pointer; }
.mall-cat-circle {
  width:62px; height:62px; border-radius:16px;
  margin-bottom:5px;
  border:3px solid rgba(255,255,255,0.3);
  display:flex; align-items:center;
  justify-content:center; font-size:26px;
}
.mall-cat span { font-size:10px; color:white; font-weight:700; display:block; }

/* ===== MINI CAROUSEL (inside mall) ===== */
.mini-carousel-wrap { border-radius:var(--radius); overflow:hidden; }
.mini-carousel { display:flex; transition:transform 0.4s ease; }
.mini-slide {
  min-width:100%; height:120px;
  display:flex; align-items:center;
  padding:0 18px; cursor:pointer;
}
.mini-slide-text h3 { color:white; font-size:15px; font-weight:800; margin-bottom:3px; }
.mini-slide-text p { color:rgba(255,255,255,0.85); font-size:11px; margin-bottom:8px; }
.mini-shop-btn {
  background:white; color:var(--secondary);
  font-size:11px; font-weight:800;
  padding:5px 14px; border-radius:20px;
  border:none; cursor:pointer; font-family:var(--font);
}

/* ===== BUDGET SECTION ===== */
.budget-banner {
  background:linear-gradient(135deg,#f093fb,#f5576c);
  padding:14px 14px 0;
}
.budget-banner-title { color:white; font-family:var(--font-display); font-size:16px; font-weight:800; margin-bottom:12px; }

/* ===== REVIEWS ===== */
.review-card {
  background:white; border-radius:var(--radius);
  padding:12px; box-shadow:var(--shadow);
  flex-shrink:0; width:230px;
  border-left:3px solid var(--primary);
}
.reviewer { display:flex; align-items:center; gap:8px; margin-bottom:8px; }
.r-avatar {
  width:34px; height:34px; border-radius:50%;
  background:var(--primary-light);
  display:flex; align-items:center;
  justify-content:center; font-size:14px;
  font-weight:800; color:var(--primary);
}
.r-name { font-size:12px; font-weight:800; }
.r-stars { font-size:11px; color:var(--accent); }
.r-text { font-size:11px; color:var(--text-muted); line-height:1.5; }
.r-product { font-size:10px; color:var(--primary); margin-top:6px; font-weight:700; }

/* ===== NEWSLETTER ===== */
.newsletter-box {
  background:linear-gradient(135deg,#0f172a,#1e293b);
  margin:0 -14px; padding:20px 14px;
}
.newsletter-box h3 { color:white; font-family:var(--font-display); font-size:17px; margin-bottom:5px; }
.newsletter-box p { color:rgba(255,255,255,0.7); font-size:12px; margin-bottom:14px; }
.newsletter-input-wrap { display:flex; gap:8px; }
.newsletter-input-wrap input {
  flex:1; background:rgba(255,255,255,0.1);
  border:1.5px solid rgba(255,255,255,0.2);
  border-radius:10px; padding:10px 14px;
  font-size:13px; color:white; outline:none;
  font-family:var(--font);
}
.newsletter-input-wrap input::placeholder { color:rgba(255,255,255,0.5); }
.newsletter-input-wrap button {
  background:var(--primary); color:white;
  border:none; border-radius:10px;
  padding:10px 18px; font-size:13px;
  font-weight:800; cursor:pointer; font-family:var(--font);
}

/* ===== FOOTER ===== */
.footer {
  background:#0f172a; color:rgba(255,255,255,0.7);
  padding:20px 14px; font-size:12px;
}
.footer-links { display:flex; flex-wrap:wrap; gap:12px; margin-bottom:14px; }
.footer-link {
  color:rgba(255,255,255,0.6); cursor:pointer;
  text-decoration:underline;
}
.footer-link:hover { color:white; }
.footer-social { display:flex; gap:10px; margin-bottom:14px; }
.social-btn {
  background:rgba(255,255,255,0.1);
  border:none; color:white;
  width:36px; height:36px;
  border-radius:50%; display:flex;
  align-items:center; justify-content:center;
  font-size:16px; cursor:pointer;
}
.footer-copy { font-size:11px; color:rgba(255,255,255,0.4); }

/* ===== BOTTOM NAV ===== */
.bottom-nav {
  position:fixed; bottom:0;
  left:50%; transform:translateX(-50%);
  width:100%; max-width:480px;
  background:white; border-top:1px solid var(--border);
  display:flex; box-shadow:0 -4px 24px rgba(0,0,0,0.1);
  z-index:200; safe-area-inset-bottom:env(safe-area-inset-bottom);
  padding-bottom:env(safe-area-inset-bottom);
}
.nav-item {
  flex:1; display:flex; flex-direction:column;
  align-items:center; gap:3px;
  padding:9px 0; cursor:pointer;
  color:var(--text-muted); font-size:10px; font-weight:700;
  transition:color 0.2s; border:none;
  background:none; font-family:var(--font);
}
.nav-item.active { color:var(--primary); }
.nav-item .n-icon { font-size:21px; position:relative; }
.nav-badge {
  position:absolute; top:-5px; right:-8px;
  background:var(--primary); color:white;
  font-size:8px; font-weight:900;
  width:15px; height:15px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
}

/* ===== PAGE SYSTEM ===== */
.page { display:none; padding-bottom:72px; min-height:100vh; }
.page.active { display:block; animation:fadeUp 0.2s ease; }
@keyframes fadeUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

/* ===== PAGE HEADER ===== */
.page-header {
  background:white; padding:14px 14px;
  display:flex; align-items:center; gap:12px;
  border-bottom:1px solid var(--border);
  position:sticky; top:0; z-index:100;
}
.back-btn {
  background:none; border:none;
  font-size:22px; cursor:pointer;
  color:var(--text); padding:0; width:32px;
  display:flex; align-items:center;
}
.page-title { font-size:18px; font-weight:800; flex:1; }

/* ===== PRODUCT DETAIL ===== */
.detail-img-wrap { position:relative; }
.detail-main-img { width:100%; height:310px; object-fit:cover; display:block; }
.detail-float-btns {
  position:absolute; top:14px;
  left:14px; right:14px;
  display:flex; justify-content:space-between;
}
.float-btn {
  background:rgba(255,255,255,0.9);
  border:none; width:38px; height:38px;
  border-radius:50%; display:flex;
  align-items:center; justify-content:center;
  cursor:pointer; font-size:17px;
  box-shadow:var(--shadow); backdrop-filter:blur(4px);
}
.detail-thumbs {
  display:flex; gap:8px;
  padding:8px 14px; overflow-x:auto;
  scrollbar-width:none; background:white;
}
.detail-thumbs::-webkit-scrollbar { display:none; }
.d-thumb {
  width:62px; height:62px; border-radius:10px;
  object-fit:cover; border:2px solid transparent;
  cursor:pointer; flex-shrink:0; transition:border-color 0.2s;
}
.d-thumb.active { border-color:var(--primary); }
.detail-info { padding:14px; background:white; }
.d-cat { font-size:11px; color:var(--primary); font-weight:700; margin-bottom:4px; }
.d-name { font-size:19px; font-weight:800; margin-bottom:8px; line-height:1.3; }
.d-rating-row { display:flex; align-items:center; gap:10px; margin-bottom:12px; }
.d-rating-pill {
  background:var(--success); color:white;
  font-size:12px; font-weight:700;
  padding:4px 9px; border-radius:5px;
  display:flex; align-items:center; gap:3px;
}
.d-price-row { display:flex; align-items:baseline; gap:10px; margin-bottom:14px; flex-wrap:wrap; }
.d-price { font-size:28px; font-weight:900; color:var(--primary); font-family:var(--font-display); }
.d-orig { font-size:17px; color:var(--text-muted); text-decoration:line-through; }
.d-disc { font-size:15px; font-weight:800; color:var(--success); }
.d-highlights { background:var(--bg); border-radius:10px; padding:12px; margin-bottom:14px; }
.d-highlights ul { padding-left:16px; }
.d-highlights li { font-size:13px; color:var(--text); margin-bottom:4px; }
.pincode-check { margin-bottom:14px; }
.pincode-check label { font-size:12px; font-weight:700; color:var(--text-muted); display:block; margin-bottom:5px; }
.pincode-row { display:flex; gap:8px; }
.pincode-row input {
  flex:1; border:1.5px solid var(--border);
  border-radius:9px; padding:9px 12px;
  font-size:14px; font-family:var(--font);
  color:var(--text); outline:none;
}
.pincode-row input:focus { border-color:var(--primary); }
.pincode-row button {
  background:var(--primary); color:white;
  border:none; border-radius:9px;
  padding:9px 16px; font-size:13px;
  font-weight:700; cursor:pointer; font-family:var(--font);
}
.pincode-result { font-size:12px; font-weight:700; margin-top:6px; }
.pincode-result.ok { color:var(--success); }
.pincode-result.err { color:var(--danger); }
.delivery-box {
  background:#f0fdf4; border:1px solid #bbf7d0;
  border-radius:10px; padding:11px 13px; margin-bottom:14px;
}
.delivery-box p { font-size:12px; color:#166534; font-weight:600; margin:2px 0; }
.d-desc { font-size:13px; color:var(--text-muted); line-height:1.7; margin-bottom:16px; }
.d-specs { margin-bottom:16px; }
.d-specs table { width:100%; border-collapse:collapse; font-size:13px; }
.d-specs td { padding:8px 10px; border-bottom:1px solid var(--border); }
.d-specs td:first-child { font-weight:700; color:var(--text); width:40%; }
.d-specs td:last-child { color:var(--text-muted); }
.d-section-title { font-size:15px; font-weight:800; margin-bottom:10px; }
.detail-actions {
  display:flex; gap:10px;
  position:sticky; bottom:72px;
  padding:12px 14px; background:white;
  border-top:1px solid var(--border);
  box-shadow:0 -4px 20px rgba(0,0,0,0.08);
}
.d-wish { flex:0; background:var(--primary-light); color:var(--primary); border:none; border-radius:10px; padding:14px 16px; font-size:19px; cursor:pointer; }
.d-cart { flex:1; background:white; color:var(--primary); border:2px solid var(--primary); border-radius:10px; padding:14px; font-size:14px; font-weight:800; cursor:pointer; font-family:var(--font); }
.d-buy { flex:1; background:linear-gradient(135deg,var(--primary),var(--primary-dark)); color:white; border:none; border-radius:10px; padding:14px; font-size:14px; font-weight:800; cursor:pointer; font-family:var(--font); }

/* ===== CART ===== */
.cart-item {
  background:white; border-radius:var(--radius);
  margin:10px 14px; padding:12px;
  box-shadow:var(--shadow); display:flex; gap:12px;
}
.cart-item-img { width:82px; height:82px; border-radius:10px; object-fit:cover; flex-shrink:0; }
.cart-item-info { flex:1; }
.ci-name { font-size:13px; font-weight:700; margin-bottom:3px; line-height:1.3; }
.ci-variant { font-size:11px; color:var(--text-muted); margin-bottom:4px; }
.ci-price { font-size:16px; font-weight:900; color:var(--primary); margin-bottom:8px; }
.qty-row { display:flex; align-items:center; gap:10px; }
.qty-btn {
  background:var(--primary-light); color:var(--primary);
  border:none; width:30px; height:30px;
  border-radius:7px; font-size:18px; font-weight:800;
  cursor:pointer; display:flex; align-items:center; justify-content:center;
}
.qty-num { font-size:15px; font-weight:800; min-width:20px; text-align:center; }
.del-btn {
  color:#ef4444; background:none;
  border:none; font-size:18px;
  cursor:pointer; margin-left:auto; padding:4px;
}
.cart-summary {
  background:white; margin:10px 14px;
  border-radius:var(--radius); padding:16px;
  box-shadow:var(--shadow);
}
.sum-row {
  display:flex; justify-content:space-between;
  margin-bottom:9px; font-size:14px;
}
.sum-row.total {
  font-weight:900; font-size:17px;
  border-top:2px solid var(--border);
  padding-top:10px; margin-top:4px;
}
.coupon-row {
  display:flex; gap:8px; margin-bottom:14px;
  background:var(--bg); border-radius:10px; padding:10px;
}
.coupon-row input {
  flex:1; border:1.5px solid var(--border);
  border-radius:8px; padding:8px 12px;
  font-size:13px; font-family:var(--font); outline:none;
  text-transform:uppercase;
}
.coupon-row button {
  background:var(--secondary); color:white;
  border:none; border-radius:8px;
  padding:8px 14px; font-size:13px;
  font-weight:700; cursor:pointer; font-family:var(--font);
}
.empty-state {
  text-align:center; padding:60px 20px;
}
.empty-icon { font-size:64px; margin-bottom:16px; }
.empty-state h3 { font-size:19px; font-weight:800; margin-bottom:8px; }
.empty-state p { font-size:14px; color:var(--text-muted); margin-bottom:22px; }
.big-btn {
  background:var(--primary); color:white;
  border:none; border-radius:var(--radius);
  padding:13px 32px; font-size:15px;
  font-weight:800; cursor:pointer; font-family:var(--font);
}

/* ===== CHECKOUT ===== */
.steps-bar {
  display:flex; background:white;
  border-bottom:1px solid var(--border); padding:12px 14px;
  overflow-x:auto; scrollbar-width:none; gap:0;
}
.steps-bar::-webkit-scrollbar { display:none; }
.step-item {
  display:flex; align-items:center;
  gap:6px; flex-shrink:0;
}
.step-num {
  width:26px; height:26px; border-radius:50%;
  background:var(--border); color:var(--text-muted);
  font-size:12px; font-weight:800;
  display:flex; align-items:center; justify-content:center;
  transition:all 0.3s;
}
.step-num.active { background:var(--primary); color:white; }
.step-num.done { background:var(--success); color:white; }
.step-label { font-size:11px; font-weight:700; color:var(--text-muted); }
.step-label.active { color:var(--primary); }
.step-sep { width:20px; height:2px; background:var(--border); margin:0 4px; }
.step-sep.done { background:var(--success); }
.form-card {
  background:white; margin:10px 14px;
  border-radius:var(--radius); padding:16px;
  box-shadow:var(--shadow);
}
.form-card h3 { font-size:15px; font-weight:800; margin-bottom:14px; display:flex; align-items:center; gap:8px; }
.fg { margin-bottom:12px; }
.fg label { font-size:12px; font-weight:700; color:var(--text-muted); display:block; margin-bottom:5px; }
.fg input, .fg select, .fg textarea {
  width:100%; border:1.5px solid var(--border);
  border-radius:9px; padding:10px 12px;
  font-size:14px; font-family:var(--font);
  color:var(--text); outline:none;
  transition:border-color 0.2s;
  -webkit-appearance:none;
}
.fg input:focus, .fg select:focus, .fg textarea:focus { border-color:var(--primary); }
.fg .error-msg { font-size:11px; color:var(--danger); margin-top:4px; display:none; }
.fg.has-error input, .fg.has-error select { border-color:var(--danger); }
.fg.has-error .error-msg { display:block; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.payment-option {
  display:flex; align-items:center; gap:12px;
  border:2px solid var(--border); border-radius:12px;
  padding:12px 14px; margin-bottom:10px;
  cursor:pointer; transition:border-color 0.2s;
}
.payment-option.selected { border-color:var(--primary); background:var(--primary-light); }
.pay-radio {
  width:18px; height:18px; border-radius:50%;
  border:2px solid var(--border); flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
  transition:all 0.2s;
}
.payment-option.selected .pay-radio { border-color:var(--primary); }
.payment-option.selected .pay-radio::after {
  content:''; width:10px; height:10px;
  border-radius:50%; background:var(--primary);
}
.pay-info { flex:1; }
.pay-title { font-size:14px; font-weight:800; }
.pay-sub { font-size:11px; color:var(--text-muted); }
.pay-icon { font-size:24px; }
.shipping-option {
  display:flex; align-items:center; gap:12px;
  border:2px solid var(--border); border-radius:12px;
  padding:12px 14px; margin-bottom:10px;
  cursor:pointer; transition:border-color 0.2s;
}
.shipping-option.selected { border-color:var(--primary); background:var(--primary-light); }
.checkout-footer {
  padding:14px;
}
.checkout-btn {
  width:100%; background:linear-gradient(135deg,var(--primary),var(--primary-dark));
  color:white; border:none; border-radius:var(--radius);
  padding:16px; font-size:16px; font-weight:800;
  cursor:pointer; font-family:var(--font);
  box-shadow:0 4px 15px rgba(244,63,94,0.4);
}
.checkout-btn:disabled { opacity:0.6; cursor:not-allowed; }

/* ===== PAYMENT PAGE ===== */
.payment-card {
  background:white; margin:12px 14px;
  border-radius:var(--radius); padding:18px;
  box-shadow:var(--shadow); text-align:center;
}
.upi-display {
  background:var(--primary-light); border:2px dashed var(--primary);
  border-radius:12px; padding:14px;
  font-size:17px; font-weight:900;
  color:var(--primary); margin:12px 0;
  cursor:pointer; letter-spacing:0.5px;
}
.qr-placeholder {
  width:150px; height:150px;
  background:var(--bg);
  border:2px dashed var(--border);
  border-radius:14px;
  margin:0 auto 12px;
  display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  font-size:40px;
}
.amount-display {
  background:#fef3c7; border:1px solid #fbbf24;
  border-radius:10px; padding:12px;
  margin:12px 0;
}
.amount-display .amt { font-size:26px; font-weight:900; color:#92400e; font-family:var(--font-display); }
.amount-display p { font-size:11px; color:#92400e; }
.upload-zone {
  border:2px dashed var(--border);
  border-radius:12px; padding:24px 16px;
  cursor:pointer; margin:12px 0;
  transition:border-color 0.2s;
}
.upload-zone:hover { border-color:var(--primary); }
.upload-zone p { font-size:13px; color:var(--text-muted); margin-top:6px; }
.cod-info {
  background:#f0fdf4; border:1px solid #bbf7d0;
  border-radius:12px; padding:16px;
  margin:12px 0; text-align:left;
}
.cod-info p { font-size:13px; color:#166534; margin-bottom:6px; display:flex; align-items:center; gap:8px; }
.confirm-btn {
  width:100%; background:linear-gradient(135deg,var(--success),#059669);
  color:white; border:none; border-radius:var(--radius);
  padding:16px; font-size:16px; font-weight:800;
  cursor:pointer; font-family:var(--font); margin-top:8px;
  box-shadow:0 4px 15px rgba(16,185,129,0.4);
}

/* ===== ORDER SUCCESS ===== */
.success-wrap {
  padding:40px 20px; text-align:center;
  min-height:calc(100vh - 72px);
  display:flex; flex-direction:column; align-items:center; justify-content:center;
}
.success-anim { font-size:72px; animation:bounce 0.6s ease; margin-bottom:16px; }
@keyframes bounce { 0%{transform:scale(0)} 60%{transform:scale(1.2)} 100%{transform:scale(1)} }
.success-title { font-family:var(--font-display); font-size:24px; font-weight:800; color:var(--success); margin-bottom:8px; }
.order-id-card {
  background:var(--primary-light); border:2px solid var(--primary);
  border-radius:14px; padding:16px;
  margin:16px 0; width:100%;
}
.order-id-label { font-size:12px; color:var(--primary); font-weight:700; margin-bottom:4px; }
.order-id-val { font-family:var(--font-display); font-size:26px; font-weight:900; color:var(--primary); }
.wa-order-btn {
  width:100%; background:#25d366; color:white;
  border:none; border-radius:var(--radius);
  padding:15px; font-size:15px; font-weight:800;
  cursor:pointer; font-family:var(--font);
  display:flex; align-items:center; justify-content:center; gap:8px;
  margin-bottom:10px;
}

/* ===== TRACKING ===== */
.track-steps { margin-top:16px; }
.track-step { display:flex; gap:14px; margin-bottom:16px; }
.ts-line { display:flex; flex-direction:column; align-items:center; }
.ts-dot {
  width:16px; height:16px; border-radius:50%;
  flex-shrink:0; margin-top:2px;
}
.ts-dot.done { background:var(--success); }
.ts-dot.now { background:var(--primary); box-shadow:0 0 0 5px var(--primary-light); }
.ts-dot.wait { background:var(--border); }
.ts-connector { width:2px; flex:1; margin:4px 0; min-height:24px; }
.ts-connector.done { background:var(--success); }
.ts-connector.wait { background:var(--border); }
.ts-info { flex:1; padding-bottom:4px; }
.ts-title { font-size:14px; font-weight:800; }
.ts-desc { font-size:11px; color:var(--text-muted); margin-top:2px; }
.ts-date { font-size:11px; color:var(--primary); margin-top:2px; font-weight:700; }

/* ===== ACCOUNT ===== */
.account-banner {
  background:linear-gradient(135deg,var(--primary),var(--primary-dark));
  padding:28px 20px; text-align:center; color:white;
}
.acc-avatar {
  width:72px; height:72px; border-radius:50%;
  background:rgba(255,255,255,0.2);
  border:3px solid rgba(255,255,255,0.5);
  margin:0 auto 12px;
  display:flex; align-items:center;
  justify-content:center; font-size:32px;
}
.acc-name { font-family:var(--font-display); font-size:21px; font-weight:800; }
.acc-phone { font-size:13px; opacity:0.8; }
.menu-list {
  background:white; margin:14px;
  border-radius:var(--radius); overflow:hidden;
  box-shadow:var(--shadow);
}
.menu-item {
  display:flex; align-items:center; gap:12px;
  padding:14px 16px;
  border-bottom:1px solid var(--border);
  cursor:pointer; font-size:14px; font-weight:700;
  transition:background 0.15s;
}
.menu-item:last-child { border-bottom:none; }
.menu-item:hover { background:var(--bg); }
.menu-item .m-icon { font-size:20px; width:24px; text-align:center; }
.menu-item .m-chevron { margin-left:auto; color:var(--text-muted); font-size:18px; }

/* ===== ORDERS LIST ===== */
.order-card {
  background:white; margin:0 14px 10px;
  border-radius:var(--radius); padding:14px;
  box-shadow:var(--shadow);
}
.order-card-header { display:flex; justify-content:space-between; margin-bottom:8px; }
.order-id { font-weight:800; font-size:14px; }
.order-status {
  font-size:11px; font-weight:700;
  padding:3px 10px; border-radius:20px;
}
.status-pending { background:#fef3c7; color:#92400e; }
.status-confirmed { background:#dbeafe; color:#1d4ed8; }
.status-shipped { background:#ede9fe; color:#6d28d9; }
.status-delivered { background:#d1fae5; color:#065f46; }
.status-cancelled { background:#fee2e2; color:#991b1b; }
.order-card-body { font-size:13px; color:var(--text-muted); }
.order-card-footer { display:flex; gap:8px; margin-top:10px; }
.oc-btn {
  flex:1; border:1.5px solid var(--border);
  border-radius:8px; padding:8px;
  font-size:12px; font-weight:700;
  cursor:pointer; font-family:var(--font);
  background:none; color:var(--text);
}
.oc-btn.primary { background:var(--primary); color:white; border-color:var(--primary); }

/* ===== CATEGORY FILTER PAGE ===== */
.filter-chips {
  display:flex; gap:8px; padding:10px 14px;
  background:white; border-bottom:1px solid var(--border);
  overflow-x:auto; scrollbar-width:none;
}
.filter-chips::-webkit-scrollbar { display:none; }
.fc {
  flex-shrink:0; padding:6px 14px;
  border-radius:20px; font-size:12px;
  font-weight:700; border:1.5px solid var(--border);
  cursor:pointer; white-space:nowrap;
  display:flex; align-items:center; gap:5px;
}
.fc.active { background:var(--primary); color:white; border-color:var(--primary); }

/* ===== POLICY PAGES ===== */
.policy-body { padding:16px 14px; }
.policy-body h2 { font-size:17px; margin-bottom:10px; margin-top:18px; }
.policy-body h2:first-child { margin-top:0; }
.policy-body p { font-size:13px; color:var(--text-muted); margin-bottom:10px; line-height:1.7; }
.policy-body ul { padding-left:18px; margin-bottom:10px; }
.policy-body li { font-size:13px; color:var(--text-muted); margin-bottom:5px; line-height:1.6; }

/* ===== BLOG ===== */
.blog-card {
  background:white; border-radius:var(--radius);
  overflow:hidden; box-shadow:var(--shadow); margin:10px 14px;
  cursor:pointer; transition:transform 0.2s;
}
.blog-card:active { transform:scale(0.98); }
.blog-img { width:100%; height:160px; object-fit:cover; display:block; }
.blog-info { padding:14px; }
.blog-cat { font-size:10px; font-weight:800; color:var(--primary); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:5px; }
.blog-title { font-size:15px; font-weight:800; margin-bottom:6px; line-height:1.3; }
.blog-excerpt { font-size:12px; color:var(--text-muted); line-height:1.5; margin-bottom:8px; }
.blog-meta { font-size:11px; color:var(--text-muted); }

/* ===== FAQ ===== */
.faq-item { background:white; border-radius:12px; margin:8px 14px; overflow:hidden; box-shadow:var(--shadow); }
.faq-q {
  padding:14px 16px; font-size:14px; font-weight:700;
  cursor:pointer; display:flex; justify-content:space-between;
  align-items:center; gap:10px;
}
.faq-q .faq-icon { font-size:18px; transition:transform 0.3s; flex-shrink:0; }
.faq-item.open .faq-icon { transform:rotate(45deg); }
.faq-a {
  padding:0 16px; max-height:0; overflow:hidden;
  transition:max-height 0.3s ease, padding 0.3s;
  font-size:13px; color:var(--text-muted); line-height:1.6;
}
.faq-item.open .faq-a { max-height:300px; padding:0 16px 14px; }

/* ===== CONTACT ===== */
.contact-options { padding:14px; }
.contact-card {
  background:white; border-radius:var(--radius);
  padding:16px; margin-bottom:12px;
  box-shadow:var(--shadow); display:flex;
  align-items:center; gap:14px; cursor:pointer;
  transition:transform 0.2s;
}
.contact-card:active { transform:scale(0.98); }
.contact-icon {
  width:50px; height:50px; border-radius:14px;
  display:flex; align-items:center;
  justify-content:center; font-size:24px; flex-shrink:0;
}
.contact-info h3 { font-size:15px; font-weight:800; margin-bottom:3px; }
.contact-info p { font-size:12px; color:var(--text-muted); }

/* ===== TOAST ===== */
.toast {
  position:fixed; top:20px;
  left:50%; transform:translateX(-50%) translateY(-100px);
  background:#1e293b; color:white;
  padding:11px 22px; border-radius:25px;
  font-size:13px; font-weight:700;
  z-index:9999; transition:transform 0.3s cubic-bezier(.4,0,.2,1);
  white-space:nowrap; max-width:90%;
  box-shadow:0 4px 20px rgba(0,0,0,0.3);
}
.toast.show { transform:translateX(-50%) translateY(0); }
.toast.success { background:var(--success); }
.toast.error { background:var(--danger); }
.toast.warning { background:var(--warning); color:#1e293b; }

/* ===== WHATSAPP FLOAT ===== */
.wa-float {
  position:fixed; bottom:82px; right:16px;
  background:#25d366; color:white;
  width:52px; height:52px; border-radius:50%;
  display:flex; align-items:center;
  justify-content:center; font-size:26px;
  cursor:pointer; z-index:150;
  box-shadow:0 4px 18px rgba(37,211,102,0.45);
  text-decoration:none; animation:pulse 2.5s infinite;
}
@keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.08)} }

/* ===== SKELETON LOADER ===== */
@keyframes shimmer { 0%{background-position:-200% 0} 100%{background-position:200% 0} }
.skeleton {
  background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);
  background-size:200% 100%;
  animation:shimmer 1.5s infinite;
  border-radius:8px;
}

/* ===== REVIEW FORM ===== */
.star-picker { display:flex; gap:6px; margin-bottom:12px; }
.star-opt { font-size:28px; cursor:pointer; opacity:0.3; transition:opacity 0.2s, transform 0.2s; }
.star-opt.active { opacity:1; transform:scale(1.15); }

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width:3px; height:3px; }
::-webkit-scrollbar-thumb { background:var(--border); border-radius:2px; }

/* ===== MISC ===== */
.tag {
  display:inline-block; font-size:10px; font-weight:700;
  padding:3px 8px; border-radius:5px; margin:2px;
}
.tag-blue { background:#dbeafe; color:#1d4ed8; }
.tag-green { background:#d1fae5; color:#065f46; }
.tag-yellow { background:#fef3c7; color:#92400e; }
.info-strip {
  background:#fef3c7; border:1px solid #fcd34d;
  padding:10px 14px; font-size:11px; color:#92400e;
  display:flex; align-items:flex-start; gap:7px;
  margin:10px 14px; border-radius:10px;
}
</style>
</head>
<body>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- WHATSAPP FLOAT -->
<a href="https://wa.me/917866048085?text=Hi! I need help with my ShopIndia order." class="wa-float" target="_blank" rel="noopener">💬</a>

<!-- ===================== HOME PAGE ===================== -->
<div class="page active" id="page-home">
  <!-- HEADER -->
  <div class="header">
    <div class="header-top">
      <div class="logo" onclick="showPage('page-home')">Shop<em>India</em><sup>™</sup></div>
      <div class="header-icons">
        <button class="icon-btn" onclick="showPage('page-wishlist')" title="Wishlist">❤️</button>
        <button class="icon-btn" onclick="showPage('page-cart')" title="Cart">
          🛒<span class="badge" id="cart-count">0</span>
        </button>
      </div>
    </div>
    <div class="search-wrap">
      <div class="search-bar">
        <input type="text" id="search-input" placeholder="Search sarees, earphones, kurtis..." autocomplete="off"
          oninput="showSuggestions(this.value)" onblur="setTimeout(hideSuggestions,200)">
        <button onclick="doSearch()">🔍</button>
      </div>
      <div class="search-suggestions" id="suggestions"></div>
    </div>
  </div>

  <!-- CATEGORY CHIPS -->
  <div class="cat-chips">
    <div class="chip active" onclick="filterChip(this,'all')">✨ All</div>
