<script>
/* ============================================================
   CONFIG — Edit these values to customise your store
   ============================================================ */
const CONFIG = {
  storeName: 'ShopIndia',
  upiId: 'tanvir786@ptaxis',
  whatsapp: '917866048085',
  freeShippingAbove: 499,
  standardShipping: 49,
  expressShipping: 99,
  gstRate: 0.18,    // 18% GST
  adminUrl: '../admin/index.html',
  // Coupons: code -> {type:'percent'|'flat', value, minOrder}
  coupons: {
    'FLAT10': { type:'percent', value:10, minOrder:0, desc:'10% off' },
    'SHIP49': { type:'flat', value:49, minOrder:199, desc:'Free shipping' },
    'SAVE50': { type:'flat', value:50, minOrder:499, desc:'₹50 off on ₹499+' },
