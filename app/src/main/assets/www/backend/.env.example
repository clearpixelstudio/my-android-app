# ShopIndia Environment Variables
# Copy this to .env and fill in real values before deploying

# Server
PORT=3001
NODE_ENV=production

# Admin Auth (CHANGE THESE!)
ADMIN_USER=admin
ADMIN_PASS=shopindia123
ADMIN_TOKEN=shopindia-admin-secret-token-change-this

# Business Settings
UPI_ID=tanvir786@ptaxis
WHATSAPP=917866048085
STORE_NAME=ShopIndia

# CORS - set to your frontend domain
ALLOWED_ORIGIN=https://yourstore.netlify.app

# Razorpay (TEST mode keys - get from razorpay.com/dashboard)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Email (Nodemailer / SendGrid)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# FROM_EMAIL=noreply@shopindia.in

# SendGrid (alternative to SMTP)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# WhatsApp Business API (optional)
# WABA_TOKEN=your_whatsapp_business_token
# WABA_PHONE_ID=your_phone_number_id

# MongoDB (upgrade from JSON files when ready)
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/shopindia
